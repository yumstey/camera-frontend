# Park Analytics – Environment Variables
# Bu faylni .env deb nusxa oling va o'z qiymatlaringizni yozing

# Backend API URL
VITE_API_BASE_URL=https://your-api.com/api

# WebSocket URL (real-time stats uchun)
VITE_WS_URL=wss://your-api.com/ws/stats

# JWT Token (agar kerak bo'lsa – analyticsApi.js dagi Authorization ni yoqing)
# VITE_AUTH_TOKEN=your_token_here
